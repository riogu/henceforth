digraph CFG {
    node [shape=box fontname="Monospace"]
    subgraph cluster_print {
        label="fn print";
        print_start_1 [label="start_1:\l  %0 = str %arg0\l  %1 = (%0)\l  return %1\l"];
    }
    subgraph cluster_fizz_buzz {
        label="fn fizz_buzz";
        fizz_buzz_start_2 [label="start_2:\l  %0 = i32 %arg0\l  %1 = 15\l  %2 = %0 % %1\l  %3 = 0\l  %4 = %2 == %3\l  branch %4 ,if_body_3 else_if_cond_5\l"];
        fizz_buzz_if_body_3 [label="if_body_3:\l  %5 = \"fizzbuzz\"\l  jump if_end_4\l"];
        fizz_buzz_if_end_4 [label="if_end_4:\l  %6 = phi [if_body_3: %5],[if_body_6: %12],[if_body_8: %17],[else_body_9: %18]\l  %7 = (%6)\l  return %7\l"];
        fizz_buzz_else_if_cond_5 [label="else_if_cond_5:\l  %8 = 3\l  %9 = %0 % %8\l  %10 = 0\l  %11 = %9 == %10\l  branch %11 ,if_body_6 else_if_cond_7\l"];
        fizz_buzz_if_body_6 [label="if_body_6:\l  %12 = \"fizz\"\l  jump if_end_4\l"];
        fizz_buzz_else_if_cond_7 [label="else_if_cond_7:\l  %13 = 5\l  %14 = %0 % %13\l  %15 = 0\l  %16 = %14 == %15\l  branch %16 ,if_body_8 else_body_9\l"];
        fizz_buzz_if_body_8 [label="if_body_8:\l  %17 = \"buzz\"\l  jump if_end_4\l"];
        fizz_buzz_else_body_9 [label="else_body_9:\l  %18 = \"no fizzbuzz\"\l  jump if_end_4\l"];
        fizz_buzz_start_2 -> fizz_buzz_if_body_3 [label="true"];
        fizz_buzz_start_2 -> fizz_buzz_else_if_cond_5 [label="false"];
        fizz_buzz_if_body_3 -> fizz_buzz_if_end_4;
        fizz_buzz_else_if_cond_5 -> fizz_buzz_if_body_6 [label="true"];
        fizz_buzz_else_if_cond_5 -> fizz_buzz_else_if_cond_7 [label="false"];
        fizz_buzz_if_body_6 -> fizz_buzz_if_end_4;
        fizz_buzz_else_if_cond_7 -> fizz_buzz_if_body_8 [label="true"];
        fizz_buzz_else_if_cond_7 -> fizz_buzz_else_body_9 [label="false"];
        fizz_buzz_if_body_8 -> fizz_buzz_if_end_4;
        fizz_buzz_else_body_9 -> fizz_buzz_if_end_4;
    }
    subgraph cluster_main {
        label="fn main";
        main_start_10 [label="start_10:\l  %0 = 67\l  %1 = call fizz_buzz(%0)\l  %2 = retval str\l  %3 = call print(%2)\l  %4 = retval str\l  %5 = ()\l  return %5\l"];
    }
}
