
fn print: (str) -> () { @pop }
fn factorial: (i32 i32) -> (i32) {
    @pop
    let n: i32;
    let result: i32;
    &= n;
    @(1) &= result;
    while @(n 1 >) {
        @(result n *) &= result;
        @(n 1 -) &= n;
    }
    @(result);
}

fn main: () -> () {
    @( 5 312) &> factorial;
    if @(@dup 120 ==) {
        @("factorial example\n") &> print;
    }
    @pop 
}
